{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".github/copilot-instructions.md",
    ".github/instructions/**/*.instructions.md",
    "CONTROLLED_MAINTENANCE.md",
    "MODULE_SYSTEM.md",
    "SOURCE_SYNC.md"
  ],
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "id_rsa": "deny",
      "id_rsa.*": "deny"
    },
    "edit": {
      "*": "deny",
      "AGENTS.md": "ask",
      "opencode.json": "ask",
      "CODEOWNERS": "ask",
      ".vscode/settings.json": "ask",
      ".github/copilot-instructions.md": "ask",
      ".github/instructions/**": "ask",
      ".github/workflows/validate-maintenance.yml": "ask",
      "modules/**": "ask",
      "maintenance/**": "ask",
      "module_registry.json": "ask",
      "sync_manifest.json": "ask"
    },
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "python scripts/validate_provenance.py": "allow",
      "python scripts/validate_registries.py": "allow",
      "python -m json.tool opencode.json": "allow",
      "python -m json.tool module_registry.json": "allow",
      "python -m json.tool sync_manifest.json": "allow",
      "python -m json.tool .vscode/settings.json": "allow",
      "git add *": "ask",
      "git commit *": "ask",
      "git push": "deny",
      "git push *": "deny",
      "rm -rf *": "deny",
      "rm -r *": "deny"
    },
    "webfetch": "ask",
    "websearch": "ask",
    "external_directory": "deny"
  }
}
